-        model.session_emb.initialize_vocab(self.get_session_ids())
+        # TRANSFER (§2.5): when finetuning from a pretrained ckpt, the model already carries a
+        # vocab; EXTEND it with the new dataset's units/sessions (random-init) and learn only
+        # those (core frozen via configure_optimizers). Otherwise initialize fresh.
+        # SEAM: load_pretrained restores embedding WEIGHTS; if it does NOT restore the vocab
+        # word->index map (InfiniteVocabEmbedding.vocab is a plain dict, not in state_dict),
+        # call model.unit_emb.initialize_vocab(<pretrained_unit_ids>) BEFORE extend_vocab so
+        # the pretrained rows keep their identities. See TRANSFER.md "vocab persistence".
+        _ft = self.cfg.get("finetune", None)
+        if _ft is not None and _ft.get("pretrained_ckpt", None):
+            model.unit_emb.extend_vocab(self.get_unit_ids(), exist_ok=True)
+            model.session_emb.extend_vocab(self.get_session_ids(), exist_ok=True)
+        else:
+            model.unit_emb.initialize_vocab(self.get_unit_ids())
+            model.session_emb.initialize_vocab(self.get_session_ids())
 
